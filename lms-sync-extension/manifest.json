{
  "manifest_version": 3,
  "name": "AcademiFlow LMS Sync Helper",
  "version": "1.0.0",
  "description": "Sinkronisasi otomatis tugas kuliah dari portal LMS kustom kampus ke AcademiFlow Anda.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://academiflow-ilham.web.app/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}
